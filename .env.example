# Plugin connects to the host's database (shared PostgreSQL, isolated schema)
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Azure OpenAI (optional — only needed for AI gap-filler)
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT="gpt-4.1-mini"
AZURE_OPENAI_API_VERSION="2024-10-21"
AZURE_OPENAI_TIMEOUT_MS="30000"

# Plugin feature flags
SENSORY_AUTO_APPLY_CONFIDENCE="0.85"
SENSORY_RATE_LIMIT_SEARCH_PER_MIN="60"
SENSORY_RATE_LIMIT_WRITE_PER_MIN="30"
